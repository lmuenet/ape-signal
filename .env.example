# Ape Signal — environment template.
# Copy to /etc/ape-signal.env on the VPS (chmod 600). NEVER commit real values.
#
# PREREQUISITE — Claude needs NO key here. It runs via the Claude Code CLI under
# your subscription. Install the CLI and run `claude login` (paste the token) ONCE
# as the SAME OS user the systemd services run as. Verify with `npm run doctor`.

# Telegram (BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Finnhub (earnings + news) — optional; the briefing degrades without it.
FINNHUB_API_KEY=

# Reddit off-radar crawl via the Reddit OAuth API (opt-in).
# Create a "script" app at https://www.reddit.com/prefs/apps to get id + secret.
# Application-only OAuth (client_credentials) works from datacenter/VPS IPs,
# unlike scraping old.reddit.com which Reddit blocks by network policy.
ENABLE_REDDIT_CRAWL=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ape-signal/0.1 (off-radar scan)
REDDIT_SUBREDDITS=wallstreetbets,wallstreetbetsGER,shortsqueeze

# Language of ALL AI free text (Persona journal/Kür/tick, scan + strategy free
# text). Supported: de | en. Default de when unset. An unsupported value makes
# the affected service fail fast at startup. JSON keys/enums stay English.
APE_LANGUAGE=de

# Handelssession (A2). Modus us (Default), xetra oder xetra+us.
#   us       = 15:30–22:00, Kür 15:15 (Europe/Berlin)
#   xetra    = 09:00–17:30, Kür 08:45
#   xetra+us = beide Märkte: Fenster 09:00–22:00, ZWEI Kürs (08:45 + 15:15);
#              Opportunismus läuft durchgehend dazwischen.
# Börsen-Feiertage (NYSE + Xetra) sind pro Markt hinterlegt (src/config/marketCalendar.ts,
# jährlich pflegen): eine Pre-Session-Kür wird an einem Feiertag IHRES Marktes
# übersprungen; der Tick pausiert nur, wenn ALLE aktiven Märkte zu sind.
# Einzelwert-Overrides (unten) gelten NUR in den Single-Market-Modi us/xetra.
# Nach Änderung: `npm run gen-timers && systemctl daemon-reload` (bei Moduswechsel
# zusätzlich neue Kür-Timer enable / alte disable).
SESSION=us
#SESSION_OPEN=15:30
#SESSION_CLOSE=22:00
#SESSION_KUER_SCAN=15:15
# Effektives Tick-Intervall in Minuten (1–60, Default 5). Empfehlung: >= 5,
# um TradingView nicht zu belagern. Live änderbar per Telegram: /ticker N.
TICK_INTERVAL_MIN=5

# Tuning (optional)
SCAN_LIMIT=15
# Where the listener persists its Telegram getUpdates offset.
OFFSET_PATH=/opt/ape-signal/.telegram-offset

# Telegram-Lautstärke: welche AUTONOMEN Nachrichten in den Chat dürfen. Das
# ape-ui-Journal behält IMMER alles — das hier schaltet nur den Chat leiser.
# Kategorien: trade (Order platziert/gefüllt, SL/TP angepasst, Close),
#   digest (Tagesabschluss), alert (Risiko/Crash/Monitor-blind/Kür-Ausfall),
#   progress (Status/Pings/„läuft noch"), research (Scan-Report/Setup/Research-Spiegel).
#   "all" = alles. Antworten auf eigene Befehle (/scan, /strategie …) sind immer an.
# Default (leer): trade,digest,alert  → progress + research sind stumm.
#TELEGRAM_VERBOSITY=trade,digest,alert

# Paper trading "Mr Ape" (opt-in): simulated depot, candidate selection after the
# PreUS scan, half-hourly ticks during the US session, daily close summary.
# State lives in DATA_DIR (default <repo>/data): portfolio.json + journal.md.
# Fills simulate Smartbroker+-style costs: 0.99 per execution below 500 order
# volume (free above) plus a 0.1% half-spread on market-type executions.
ENABLE_PAPER_TRADING=
PAPER_START_BALANCE=2000
#DATA_DIR=/opt/ape-signal/data

# Intraday opportunism (Stufe 3): when on, a deterministic Setup-Radar trigger
# (EMA10x20 cross / RSI extreme on a watched, non-held ticker) may open ONE
# intraday LIMIT order in a separate budget tier (max 1/day, on top of the daily
# cap), never doubling down on a held ticker. OFF by default — the Setup-Radar
# still ALERTS setups on Telegram without this flag.
ENABLE_INTRADAY_OPPORTUNISM=
