# Ape Signal — environment template.
# Copy to /etc/ape-signal.env on the VPS (chmod 600). NEVER commit real values.
# Claude needs NO key here — it runs via `claude login` (subscription).

# Telegram (BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Reddit "script app" (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ape-signal/0.1 by u_yourname

# Finnhub (news + earnings)
FINNHUB_API_KEY=
